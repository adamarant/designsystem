{
  "name": "@adamarant/ds-react",
  "version": "1.3.0",
  "description": "React layout primitives for @adamarant/designsystem — Flex, Stack, Grid, Text, Center. Props map to ds-* classes, zero logic.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./Flex": {
      "types": "./dist/primitives/Flex.d.ts",
      "import": "./dist/primitives/Flex.js"
    },
    "./Stack": {
      "types": "./dist/primitives/Stack.d.ts",
      "import": "./dist/primitives/Stack.js"
    },
    "./Grid": {
      "types": "./dist/primitives/Grid.d.ts",
      "import": "./dist/primitives/Grid.js"
    },
    "./Text": {
      "types": "./dist/primitives/Text.d.ts",
      "import": "./dist/primitives/Text.js"
    },
    "./Center": {
      "types": "./dist/primitives/Center.d.ts",
      "import": "./dist/primitives/Center.js"
    },
    "./Label": {
      "types": "./dist/components/Label.d.ts",
      "import": "./dist/components/Label.js"
    },
    "./Button": {
      "types": "./dist/components/Button.d.ts",
      "import": "./dist/components/Button.js"
    },
    "./Badge": {
      "types": "./dist/components/Badge.d.ts",
      "import": "./dist/components/Badge.js"
    },
    "./Input": {
      "types": "./dist/components/Input.d.ts",
      "import": "./dist/components/Input.js"
    },
    "./Card": {
      "types": "./dist/components/Card.d.ts",
      "import": "./dist/components/Card.js"
    },
    "./Alert": {
      "types": "./dist/components/Alert.d.ts",
      "import": "./dist/components/Alert.js"
    },
    "./Tag": {
      "types": "./dist/components/Tag.d.ts",
      "import": "./dist/components/Tag.js"
    },
    "./Avatar": {
      "types": "./dist/components/Avatar.d.ts",
      "import": "./dist/components/Avatar.js"
    },
    "./Spinner": {
      "types": "./dist/components/Spinner.d.ts",
      "import": "./dist/components/Spinner.js"
    },
    "./Modal": {
      "types": "./dist/components/Modal.d.ts",
      "import": "./dist/components/Modal.js"
    },
    "./Tabs": {
      "types": "./dist/components/Tabs.d.ts",
      "import": "./dist/components/Tabs.js"
    },
    "./Dropdown": {
      "types": "./dist/components/Dropdown.d.ts",
      "import": "./dist/components/Dropdown.js"
    },
    "./ContextMenu": {
      "types": "./dist/components/ContextMenu.d.ts",
      "import": "./dist/components/ContextMenu.js"
    },
    "./Tooltip": {
      "types": "./dist/components/Tooltip.d.ts",
      "import": "./dist/components/Tooltip.js"
    },
    "./Toggle": {
      "types": "./dist/components/Toggle.d.ts",
      "import": "./dist/components/Toggle.js"
    },
    "./TurnstileWidget": {
      "types": "./dist/components/TurnstileWidget.d.ts",
      "import": "./dist/components/TurnstileWidget.js"
    },
    "./ClipReveal": {
      "types": "./dist/components/ClipReveal.d.ts",
      "import": "./dist/components/ClipReveal.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "clsx": "^2.1.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "react",
    "design-system",
    "layout-primitives",
    "css-classes",
    "flex",
    "grid",
    "text"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamarant/designsystem.git",
    "directory": "packages/ds-react"
  },
  "publishConfig": {
    "access": "public"
  }
}
